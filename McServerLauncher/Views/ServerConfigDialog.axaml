<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:McServerLauncher.Localization"
        x:Class="McServerLauncher.Views.ServerConfigDialog"
        Title="{loc:Loc Cfg_Title}"
        Width="760" Height="780" MinWidth="640"
        WindowStartupLocation="CenterOwner">
    <Window.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#15FFFFFF" />
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="TextBlock.title">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style Selector="TextBlock.desc">
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style Selector="TextBlock.section">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="2,14,0,8" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0" Margin="20,20,20,4" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="HeaderText" FontSize="13" Opacity="0.8" TextWrapping="Wrap" Margin="2,0,0,4" />

                <!-- ===================== GENERAL ===================== -->
                <TextBlock Text="{loc:Loc Cfg_General}" Classes="section" />

                <Border Classes="card">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Cfg_Motd}" Classes="title" />
                        <TextBlock Classes="desc" Text="{loc:Loc Cfg_MotdDesc}" />
                        <TextBox x:Name="MotdBox" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Classes="card">
                    <Grid ColumnDefinitions="*,180">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_Gamemode}" Classes="title" />
                            <TextBlock Classes="desc" Text="{loc:Loc Cfg_GamemodeDesc}" />
                        </StackPanel>
                        <ComboBox x:Name="GamemodeBox" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="{loc:Loc Gm_Survival}" Tag="survival" />
                            <ComboBoxItem Content="{loc:Loc Gm_Creative}" Tag="creative" />
                            <ComboBoxItem Content="{loc:Loc Gm_Adventure}" Tag="adventure" />
                            <ComboBoxItem Content="{loc:Loc Gm_Spectator}" Tag="spectator" />
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Classes="card">
                    <Grid ColumnDefinitions="*,180">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_Difficulty}" Classes="title" />
                            <TextBlock Classes="desc" Text="{loc:Loc Cfg_DifficultyDesc}" />
                        </StackPanel>
                        <ComboBox x:Name="DifficultyBox" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="{loc:Loc Diff_Peaceful}" Tag="peaceful" />
                            <ComboBoxItem Content="{loc:Loc Diff_Easy}" Tag="easy" />
                            <ComboBoxItem Content="{loc:Loc Diff_Normal}" Tag="normal" />
                            <ComboBoxItem Content="{loc:Loc Diff_Hard}" Tag="hard" />
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Classes="card">
                    <Grid ColumnDefinitions="*,140">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_MaxPlayers}" Classes="title" />
                            <TextBlock Classes="desc" Text="{loc:Loc Cfg_MaxPlayersDesc}" />
                        </StackPanel>
                        <NumericUpDown x:Name="MaxPlayersBox" Grid.Column="1" Minimum="1" Maximum="1000" Increment="1" FormatString="0" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- ===================== GAMEPLAY ===================== -->
                <TextBlock Text="{loc:Loc Cfg_Gameplay}" Classes="section" />

                <Border Classes="card">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_Pvp}" Classes="title" />
                            <TextBlock Classes="desc" Text="{loc:Loc Cfg_PvpDesc}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="PvpToggle" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Classes="card">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_Hardcore}" Classes="title" />
                            <TextBlock Classes="desc" Text="{loc:Loc Cfg_HardcoreDesc}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="HardcoreToggle" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Classes="card">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_Flight}" Classes="title" />
                            <TextBlock Classes="desc" Text="{loc:Loc Cfg_FlightDesc}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="AllowFlightToggle" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Classes="card">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_CmdBlocks}" Classes="title" />
                            <TextBlock Classes="desc" Text="{loc:Loc Cfg_CmdBlocksDesc}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="CommandBlockToggle" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Classes="card">
                    <Grid ColumnDefinitions="*,140">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_SpawnProt}" Classes="title" />
                            <TextBlock Classes="desc" Text="{loc:Loc Cfg_SpawnProtDesc}" />
                        </StackPanel>
                        <NumericUpDown x:Name="SpawnProtectionBox" Grid.Column="1" Minimum="0" Maximum="10000" Increment="1" FormatString="0" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- ===================== PERFORMANCE / WORLD ===================== -->
                <TextBlock Text="{loc:Loc Cfg_Performance}" Classes="section" />

                <Border Classes="card">
                    <Grid ColumnDefinitions="*,140">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_ViewDist}" Classes="title" />
                            <TextBlock Classes="desc" Text="{loc:Loc Cfg_ViewDistDesc}" />
                        </StackPanel>
                        <NumericUpDown x:Name="ViewDistanceBox" Grid.Column="1" Minimum="2" Maximum="32" Increment="1" FormatString="0" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Classes="card">
                    <Grid ColumnDefinitions="*,140">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_SimDist}" Classes="title" />
                            <TextBlock Classes="desc" Text="{loc:Loc Cfg_SimDistDesc}" />
                        </StackPanel>
                        <NumericUpDown x:Name="SimulationDistanceBox" Grid.Column="1" Minimum="2" Maximum="32" Increment="1" FormatString="0" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Classes="card">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_GenStructures}" Classes="title" />
                            <TextBlock Classes="desc" Text="{loc:Loc Cfg_GenStructuresDesc}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="GenerateStructuresToggle" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- ===================== NETWORK & ACCESS ===================== -->
                <TextBlock Text="{loc:Loc Cfg_Network}" Classes="section" />

                <Border Classes="card">
                    <Grid ColumnDefinitions="*,140">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Port}" Classes="title" />
                            <TextBlock Classes="desc" Text="{loc:Loc Cfg_PortDesc}" />
                        </StackPanel>
                        <NumericUpDown x:Name="PortBox" Grid.Column="1" Minimum="1" Maximum="65535" Increment="1" FormatString="0" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Classes="card">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_OnlineMode}" Classes="title" />
                            <TextBlock Classes="desc" Text="{loc:Loc Cfg_OnlineModeDesc}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="OnlineModeToggle" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Classes="card">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Players_Whitelist}" Classes="title" />
                            <TextBlock Classes="desc" Text="{loc:Loc Cfg_WhitelistDesc}" />
                        </StackPanel>
                        <ToggleSwitch x:Name="WhitelistToggle" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,8,20,16" Spacing="8">
            <Button Content="{loc:Loc Cancel}" Click="Cancel_Click" />
            <Button Classes="accent" Content="{loc:Loc Save}" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
