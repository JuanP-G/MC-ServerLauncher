<ui:FluentWindow x:Class="McServerLauncher.Views.ServerConfigDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:loc="clr-namespace:McServerLauncher.Localization"
                 Title="{loc:Loc Cfg_Title}"
                 Width="760" Height="780"
                 MinWidth="640"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <ui:FluentWindow.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="Title" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style x:Key="Desc" TargetType="TextBlock">
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="Section" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="2,14,0,8" />
        </Style>
        <Style x:Key="RowGrid" TargetType="Grid">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{loc:Loc Cfg_Title}" />

        <ScrollViewer Grid.Row="1" Margin="20,4,20,4" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="HeaderText" FontSize="13" Opacity="0.8" TextWrapping="Wrap" Margin="2,0,0,4" />

                <!-- ===================== GENERAL ===================== -->
                <TextBlock Text="{loc:Loc Cfg_General}" Style="{StaticResource Section}" />

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Cfg_Motd}" Style="{StaticResource Title}" />
                        <TextBlock Style="{StaticResource Desc}" Text="{loc:Loc Cfg_MotdDesc}" />
                        <ui:TextBox x:Name="MotdBox" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <Grid Style="{StaticResource RowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_Gamemode}" Style="{StaticResource Title}" />
                            <TextBlock Style="{StaticResource Desc}" Text="{loc:Loc Cfg_GamemodeDesc}" />
                        </StackPanel>
                        <ComboBox x:Name="GamemodeBox" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="{loc:Loc Gm_Survival}" Tag="survival" />
                            <ComboBoxItem Content="{loc:Loc Gm_Creative}" Tag="creative" />
                            <ComboBoxItem Content="{loc:Loc Gm_Adventure}" Tag="adventure" />
                            <ComboBoxItem Content="{loc:Loc Gm_Spectator}" Tag="spectator" />
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}">
                    <Grid Style="{StaticResource RowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_Difficulty}" Style="{StaticResource Title}" />
                            <TextBlock Style="{StaticResource Desc}" Text="{loc:Loc Cfg_DifficultyDesc}" />
                        </StackPanel>
                        <ComboBox x:Name="DifficultyBox" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="{loc:Loc Diff_Peaceful}" Tag="peaceful" />
                            <ComboBoxItem Content="{loc:Loc Diff_Easy}" Tag="easy" />
                            <ComboBoxItem Content="{loc:Loc Diff_Normal}" Tag="normal" />
                            <ComboBoxItem Content="{loc:Loc Diff_Hard}" Tag="hard" />
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}">
                    <Grid Style="{StaticResource RowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_MaxPlayers}" Style="{StaticResource Title}" />
                            <TextBlock Style="{StaticResource Desc}" Text="{loc:Loc Cfg_MaxPlayersDesc}" />
                        </StackPanel>
                        <ui:NumberBox x:Name="MaxPlayersBox" Grid.Column="1" Minimum="1" Maximum="1000" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- ===================== JUGABILIDAD ===================== -->
                <TextBlock Text="{loc:Loc Cfg_Gameplay}" Style="{StaticResource Section}" />

                <Border Style="{StaticResource Card}">
                    <Grid Style="{StaticResource RowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_Pvp}" Style="{StaticResource Title}" />
                            <TextBlock Style="{StaticResource Desc}" Text="{loc:Loc Cfg_PvpDesc}" />
                        </StackPanel>
                        <ui:ToggleSwitch x:Name="PvpToggle" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}">
                    <Grid Style="{StaticResource RowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_Hardcore}" Style="{StaticResource Title}" />
                            <TextBlock Style="{StaticResource Desc}" Text="{loc:Loc Cfg_HardcoreDesc}" />
                        </StackPanel>
                        <ui:ToggleSwitch x:Name="HardcoreToggle" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}">
                    <Grid Style="{StaticResource RowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_Flight}" Style="{StaticResource Title}" />
                            <TextBlock Style="{StaticResource Desc}" Text="{loc:Loc Cfg_FlightDesc}" />
                        </StackPanel>
                        <ui:ToggleSwitch x:Name="AllowFlightToggle" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}">
                    <Grid Style="{StaticResource RowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_CmdBlocks}" Style="{StaticResource Title}" />
                            <TextBlock Style="{StaticResource Desc}" Text="{loc:Loc Cfg_CmdBlocksDesc}" />
                        </StackPanel>
                        <ui:ToggleSwitch x:Name="CommandBlockToggle" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}">
                    <Grid Style="{StaticResource RowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_SpawnProt}" Style="{StaticResource Title}" />
                            <TextBlock Style="{StaticResource Desc}" Text="{loc:Loc Cfg_SpawnProtDesc}" />
                        </StackPanel>
                        <ui:NumberBox x:Name="SpawnProtectionBox" Grid.Column="1" Minimum="0" Maximum="10000" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- ===================== RENDIMIENTO / MUNDO ===================== -->
                <TextBlock Text="{loc:Loc Cfg_Performance}" Style="{StaticResource Section}" />

                <Border Style="{StaticResource Card}">
                    <Grid Style="{StaticResource RowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_ViewDist}" Style="{StaticResource Title}" />
                            <TextBlock Style="{StaticResource Desc}" Text="{loc:Loc Cfg_ViewDistDesc}" />
                        </StackPanel>
                        <ui:NumberBox x:Name="ViewDistanceBox" Grid.Column="1" Minimum="2" Maximum="32" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}">
                    <Grid Style="{StaticResource RowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_SimDist}" Style="{StaticResource Title}" />
                            <TextBlock Style="{StaticResource Desc}" Text="{loc:Loc Cfg_SimDistDesc}" />
                        </StackPanel>
                        <ui:NumberBox x:Name="SimulationDistanceBox" Grid.Column="1" Minimum="2" Maximum="32" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}">
                    <Grid Style="{StaticResource RowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_GenStructures}" Style="{StaticResource Title}" />
                            <TextBlock Style="{StaticResource Desc}" Text="{loc:Loc Cfg_GenStructuresDesc}" />
                        </StackPanel>
                        <ui:ToggleSwitch x:Name="GenerateStructuresToggle" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- ===================== RED Y ACCESO ===================== -->
                <TextBlock Text="{loc:Loc Cfg_Network}" Style="{StaticResource Section}" />

                <Border Style="{StaticResource Card}">
                    <Grid Style="{StaticResource RowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Port}" Style="{StaticResource Title}" />
                            <TextBlock Style="{StaticResource Desc}" Text="{loc:Loc Cfg_PortDesc}" />
                        </StackPanel>
                        <ui:NumberBox x:Name="PortBox" Grid.Column="1" Minimum="1" Maximum="65535" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}">
                    <Grid Style="{StaticResource RowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Cfg_OnlineMode}" Style="{StaticResource Title}" />
                            <TextBlock Style="{StaticResource Desc}" Text="{loc:Loc Cfg_OnlineModeDesc}" />
                        </StackPanel>
                        <ui:ToggleSwitch x:Name="OnlineModeToggle" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}">
                    <Grid Style="{StaticResource RowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc Players_Whitelist}" Style="{StaticResource Title}" />
                            <TextBlock Style="{StaticResource Desc}" Text="{loc:Loc Cfg_WhitelistDesc}" />
                        </StackPanel>
                        <ui:ToggleSwitch x:Name="WhitelistToggle" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,8,20,16">
            <ui:Button Content="{loc:Loc Cancel}" Margin="0,0,8,0" Click="Cancel_Click" />
            <ui:Button Appearance="Primary" Content="{loc:Loc Save}" Click="Save_Click" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
