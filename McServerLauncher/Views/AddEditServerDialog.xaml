<ui:FluentWindow x:Class="McServerLauncher.Views.AddEditServerDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:loc="clr-namespace:McServerLauncher.Localization"
                 Title="{loc:Loc Cfg_Title}"
                 Width="620" Height="640"
                 MinWidth="560"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{loc:Loc Cfg_Title}" />

        <ScrollViewer Grid.Row="1" Margin="20,8,20,8" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{loc:Loc Cs_Name}" Margin="0,4" />
                <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="{loc:Loc Ae_Folder}" Margin="0,12,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:Button Grid.Column="1" Content="{loc:Loc Browse}" Margin="8,0,0,0" Click="BrowseFolder_Click" />
                </Grid>

                <TextBlock Text="{loc:Loc Ae_Jar}" Margin="0,12,0,4" />
                <ui:TextBox Text="{Binding JarFile, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="{loc:Loc Ae_Java}" Margin="0,12,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" Text="{Binding JavaPath, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="{loc:Loc Ae_JavaPlaceholder}" />
                    <ui:Button Grid.Column="1" Content="{loc:Loc Browse}" Margin="8,0,0,0" Click="BrowseJava_Click" />
                </Grid>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="{loc:Loc Cs_RamMin}" Margin="0,0,0,4" />
                        <ui:NumberBox Value="{Binding MinRamGb}" Minimum="1" Maximum="64" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="{loc:Loc Cs_RamMax}" Margin="0,0,0,4" />
                        <ui:NumberBox Value="{Binding MaxRamGb}" Minimum="1" Maximum="64" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="{loc:Loc Ae_ExtraArgs}" Margin="0,12,0,4" />
                <ui:TextBox Text="{Binding ExtraJvmArgs, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="p.ej. -XX:+UseG1GC" />

                <Separator Margin="0,18,0,12" />

                <CheckBox Content="{loc:Loc Cs_UsePlayit}" IsChecked="{Binding PlayitEnabled}" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,8,20,16">
            <ui:Button Content="{loc:Loc Cancel}" Margin="0,0,8,0" Click="Cancel_Click" />
            <ui:Button Appearance="Primary" Content="{loc:Loc Save}" Click="Save_Click" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
