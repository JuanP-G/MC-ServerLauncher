<ui:FluentWindow x:Class="McServerLauncher.Views.AddEditServerDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Configuración del servidor"
                 Width="620" Height="640"
                 MinWidth="560"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Configuración del servidor" />

        <ScrollViewer Grid.Row="1" Margin="20,8,20,8" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Nombre" Margin="0,4" />
                <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Carpeta del servidor" Margin="0,12,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:Button Grid.Column="1" Content="Examinar..." Margin="8,0,0,0" Click="BrowseFolder_Click" />
                </Grid>

                <TextBlock Text="Archivo .jar (relativo a la carpeta)" Margin="0,12,0,4" />
                <ui:TextBox Text="{Binding JarFile, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Ruta de Java" Margin="0,12,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" Text="{Binding JavaPath, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="java (usa el del PATH) o ruta a java.exe" />
                    <ui:Button Grid.Column="1" Content="Examinar..." Margin="8,0,0,0" Click="BrowseJava_Click" />
                </Grid>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="RAM mínima (GB)" Margin="0,0,0,4" />
                        <ui:NumberBox Value="{Binding MinRamGb}" Minimum="1" Maximum="64" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="RAM máxima (GB)" Margin="0,0,0,4" />
                        <ui:NumberBox Value="{Binding MaxRamGb}" Minimum="1" Maximum="64" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Argumentos extra de la JVM (opcional)" Margin="0,12,0,4" />
                <ui:TextBox Text="{Binding ExtraJvmArgs, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="p.ej. -XX:+UseG1GC" />

                <Separator Margin="0,18,0,12" />

                <CheckBox Content="Usar Playit.gg para este servidor (túnel a Internet)" IsChecked="{Binding PlayitEnabled}" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,8,20,16">
            <ui:Button Content="Cancelar" Margin="0,0,8,0" Click="Cancel_Click" />
            <ui:Button Appearance="Primary" Content="Guardar" Click="Save_Click" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
