<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:McServerLauncher.Localization"
        xmlns:ic="using:FluentIcons.Avalonia"
        x:Class="McServerLauncher.Views.DeleteServerDialog"
        Title="{loc:Loc Del_Title}"
        Width="500" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,Auto">
        <StackPanel Grid.Row="0" Margin="20,20,20,8">
            <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="14" />

            <CheckBox x:Name="DeleteTunnelCheck" Margin="0,16,0,0" IsChecked="True"
                      Content="{loc:Loc Del_Tunnel}" />

            <CheckBox x:Name="DeleteFilesCheck" Margin="0,10,0,0"
                      IsCheckedChanged="OnCheckChanged"
                      Content="{loc:Loc Del_Files}" />

            <Border x:Name="WarningBox" Margin="0,10,0,0" Padding="12"
                    CornerRadius="8"
                    Background="#33D13438" BorderBrush="#D13438" BorderThickness="1"
                    IsVisible="False">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <ic:SymbolIcon Symbol="Warning" Foreground="#FF6B6B" VerticalAlignment="Center" />
                    <TextBlock TextWrapping="Wrap" Foreground="#FFB3B3" Width="380"
                               Text="{loc:Loc Del_Warning}" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="FolderText" Margin="0,8,0,0" FontSize="12" Opacity="0.7"
                       TextWrapping="Wrap" IsVisible="False" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,8,20,16" Spacing="8">
            <Button Content="{loc:Loc Cancel}" Click="Cancel_Click" />
            <Button x:Name="DeleteButton" Background="#C42B1C" Foreground="White"
                    Content="{loc:Loc Del_Delete}" Click="Delete_Click" />
        </StackPanel>
    </Grid>
</Window>
