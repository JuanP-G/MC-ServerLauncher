<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="using:McServerLauncher.Localization"
        x:Class="McServerLauncher.Views.CreateServerDialog"
        Title="{loc:Loc CreateServer}"
        Width="640" Height="720" MinWidth="560"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Grid RowDefinitions="*,Auto,Auto">
        <ScrollViewer Grid.Row="0" Margin="20,20,20,8" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="FormPanel">
                <TextBlock Text="{loc:Loc Cs_Name}" Margin="0,4" />
                <TextBox x:Name="NameBox" Watermark="{loc:Loc Cs_NamePlaceholder}" />

                <TextBlock Text="{loc:Loc Cs_ParentFolder}" Margin="0,12,0,4" />
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox x:Name="ParentFolderBox" Grid.Column="0" />
                    <Button Grid.Column="1" Content="{loc:Loc Browse}" Margin="8,0,0,0" Click="BrowseParent_Click" />
                </Grid>
                <TextBlock x:Name="FinalPathText" Margin="2,4,0,0" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto" Margin="0,12,0,0">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Software" Margin="0,0,0,4" />
                        <ComboBox x:Name="TypeCombo" HorizontalAlignment="Stretch" SelectedIndex="0">
                            <ComboBoxItem Content="Vanilla" />
                            <ComboBoxItem Content="Fabric" />
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,Auto" Margin="0,12,0,0">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{loc:Loc Cs_Version}" Margin="0,0,0,4" />
                        <ComboBox x:Name="VersionCombo" HorizontalAlignment="Stretch" />
                    </StackPanel>
                    <CheckBox Grid.Column="1" x:Name="SnapshotsCheck" Content="{loc:Loc Cs_Snapshots}"
                              VerticalAlignment="Bottom" Margin="12,0,0,4" IsCheckedChanged="Snapshots_Changed" />
                </Grid>
                <TextBlock x:Name="VersionStatus" Margin="2,4,0,0" FontSize="12" Opacity="0.7" Text="{loc:Loc Cs_LoadingVersions}" />

                <Grid ColumnDefinitions="*,*,*" Margin="0,12,0,0">
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="{loc:Loc Port}" Margin="0,0,0,4" />
                        <NumericUpDown x:Name="PortBox" Value="25565" Minimum="1" Maximum="65535" Increment="1" FormatString="0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,8,0">
                        <TextBlock Text="{loc:Loc Cs_RamMin}" Margin="0,0,0,4" />
                        <NumericUpDown x:Name="MinRamBox" Value="2" Minimum="1" Maximum="64" Increment="1" FormatString="0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="8,0,0,0">
                        <TextBlock Text="{loc:Loc Cs_RamMax}" Margin="0,0,0,4" />
                        <NumericUpDown x:Name="MaxRamBox" Value="4" Minimum="1" Maximum="64" Increment="1" FormatString="0" />
                    </StackPanel>
                </Grid>
                <TextBlock x:Name="PortStatus" Margin="2,6,0,0" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                <TextBlock Margin="2,2,0,0" FontSize="12" Opacity="0.55" TextWrapping="Wrap" Text="{loc:Loc Cs_PortNote}" />

                <Separator Margin="0,18,0,12" />

                <CheckBox x:Name="PlayitCheck" Content="{loc:Loc Cs_UsePlayit}" IsChecked="True" />

                <CheckBox x:Name="CreateTunnelCheck" Margin="0,16,0,0" IsChecked="True"
                          IsEnabled="{Binding #PlayitCheck.IsChecked}"
                          Content="{loc:Loc Cs_AutoCreateTunnel}" />

                <CheckBox x:Name="AutoStartCheck" Margin="0,10,0,0" IsChecked="True"
                          Content="{loc:Loc Cs_AutoStart}" />
            </StackPanel>
        </ScrollViewer>

        <!-- Progress -->
        <Border Grid.Row="1" x:Name="ProgressBox" Margin="20,0,20,8" Padding="12"
                CornerRadius="8" Background="#1E1E1E" IsVisible="False" Height="140">
            <Grid RowDefinitions="Auto,*">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6" Spacing="8">
                    <ProgressBar x:Name="Spinner" IsIndeterminate="True" Width="120" Height="4" VerticalAlignment="Center" />
                    <TextBlock Text="{loc:Loc Cs_Creating}" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <TextBox Grid.Row="1" x:Name="ProgressLog" IsReadOnly="True" TextWrapping="Wrap"
                         Background="Transparent" BorderThickness="0" Foreground="#DDDDDD"
                         FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12"
                         AcceptsReturn="True" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,4,20,16" Spacing="8">
            <Button x:Name="CancelButton" Content="{loc:Loc Cancel}" Click="Cancel_Click" />
            <Button x:Name="CreateButton" Classes="accent" Content="{loc:Loc Cs_CreateButton}" Click="Create_Click" />
        </StackPanel>
    </Grid>
</Window>
