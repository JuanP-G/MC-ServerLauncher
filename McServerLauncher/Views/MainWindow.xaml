<ui:FluentWindow x:Class="McServerLauncher.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:McServerLauncher.ViewModels"
                 xmlns:b="clr-namespace:McServerLauncher.Behaviors"
                 Title="MC Server Launcher"
                 Width="1150" Height="720"
                 MinWidth="900" MinHeight="560"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="MC Server Launcher">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Server24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Panel lateral: lista de servidores -->
            <Border Grid.Column="0" Background="#11000000" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Servidores" FontSize="18" FontWeight="SemiBold" Margin="4,0,0,10" />

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Servers}"
                             SelectedItem="{Binding SelectedServer}"
                             Background="Transparent"
                             HorizontalContentAlignment="Stretch"
                             BorderThickness="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Margin" Value="0,1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" CornerRadius="6" Padding="6,2" Background="Transparent">
                                                <Grid>
                                                    <Rectangle x:Name="Accent" Width="3" HorizontalAlignment="Left"
                                                               RadiusX="2" RadiusY="2" Fill="#4CA3FF" Visibility="Collapsed" />
                                                    <ContentPresenter Margin="8,0,0,0" />
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#18FFFFFF" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF" />
                                                    <Setter TargetName="Accent" Property="Visibility" Value="Visible" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ServerViewModel}">
                                <Grid Margin="2,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Punto de estado con halo del color -->
                                    <Grid Grid.Column="0" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <Ellipse Fill="{Binding StatusBrush}" Opacity="0.25" />
                                        <Ellipse Width="8" Height="8" Fill="{Binding StatusBrush}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="{Binding StatusText}" FontSize="12"
                                                   Foreground="{Binding StatusBrush}" />
                                    </StackPanel>

                                    <!-- Jugadores conectados cuando está encendido -->
                                    <TextBlock Grid.Column="2" Text="{Binding PlayerCountText}" FontSize="12"
                                               Foreground="{Binding SignalBrush}" VerticalAlignment="Center"
                                               Margin="6,0,2,0"
                                               Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <ui:Button Icon="{ui:SymbolIcon Sparkle24}" Content="Crear servidor nuevo"
                                   Appearance="Primary" HorizontalAlignment="Stretch"
                                   Command="{Binding CreateServerCommand}" Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Icon="{ui:SymbolIcon FolderAdd24}" Content="Añadir"
                                       Command="{Binding AddServerCommand}" Margin="0,0,6,0"
                                       ToolTip="Añadir un servidor que ya existe en una carpeta" />
                            <ui:Button Icon="{ui:SymbolIcon Edit24}"
                                       Command="{Binding EditServerCommand}" Margin="0,0,6,0"
                                       ToolTip="Editar servidor" />
                            <ui:Button Icon="{ui:SymbolIcon Delete24}"
                                       Command="{Binding RemoveServerCommand}"
                                       ToolTip="Eliminar servidor" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Panel principal: detalle del servidor seleccionado -->
            <Grid Grid.Column="1" Margin="16">
                <TextBlock Text="Selecciona o añade un servidor para empezar."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="16" Opacity="0.6"
                           Visibility="{Binding HasSelection, Converter={StaticResource InverseBoolToVisibility}}" />

                <Grid DataContext="{Binding SelectedServer}"
                      Visibility="{Binding DataContext.HasSelection, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}, Converter={StaticResource BoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Cabecera: nombre + botones de control -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- Vista estilo lista de servidores de Minecraft -->
                        <Border Grid.Column="0" Background="#FF2B2B2B" BorderBrush="#3A3A3A" BorderThickness="1"
                                CornerRadius="6" Padding="10" Margin="0,0,16,0" VerticalAlignment="Center">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Icono del servidor (server-icon.png) o marcador si no hay. Clic para cambiarlo -->
                                <Button Grid.Column="0" Width="64" Height="64" Padding="0" Cursor="Hand"
                                        ToolTip="Clic para cambiar el icono del servidor (lo que ven los jugadores)"
                                        Command="{Binding DataContext.ChangeIconForSelectedCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Border Background="#1A1A1A" CornerRadius="2"
                                                        Visibility="{Binding HasIcon, Converter={StaticResource InverseBoolToVisibility}}">
                                                    <ui:SymbolIcon Symbol="Server24" FontSize="28" Opacity="0.5"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <Image Source="{Binding ServerIcon}" Width="64" Height="64"
                                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                       Visibility="{Binding HasIcon, Converter={StaticResource BoolToVisibility}}" />
                                                <Border x:Name="Hover" Background="#99000000" CornerRadius="2" Visibility="Collapsed">
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <ui:SymbolIcon Symbol="Edit24" FontSize="16" Foreground="White"
                                                                       HorizontalAlignment="Center" />
                                                        <TextBlock Text="Cambiar" Foreground="White" FontSize="10"
                                                                   HorizontalAlignment="Center" Margin="0,2,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Hover" Property="Visibility" Value="Visible" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Título (nombre) + MOTD con colores -->
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold"
                                               FontSize="16" TextTrimming="CharacterEllipsis" />
                                    <TextBlock b:MinecraftMotd.Text="{Binding MotdText}" FontSize="13"
                                               TextWrapping="Wrap" Margin="0,3,0,0"
                                               FontFamily="Cascadia Mono, Consolas, monospace" />
                                </StackPanel>

                                <!-- Jugadores + barras de señal -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            VerticalAlignment="Top" HorizontalAlignment="Right" Margin="10,2,0,0">
                                    <TextBlock Text="{Binding PlayerCountText}" Foreground="#AAAAAA" FontSize="13"
                                               Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                ToolTip="{Binding SignalHint}">
                                        <Rectangle Width="3" Height="4" Fill="{Binding SignalBrush}" Margin="1,0,0,0" VerticalAlignment="Bottom" />
                                        <Rectangle Width="3" Height="6" Fill="{Binding SignalBrush}" Margin="1,0,0,0" VerticalAlignment="Bottom" />
                                        <Rectangle Width="3" Height="8" Fill="{Binding SignalBrush}" Margin="1,0,0,0" VerticalAlignment="Bottom" />
                                        <Rectangle Width="3" Height="10" Fill="{Binding SignalBrush}" Margin="1,0,0,0" VerticalAlignment="Bottom" />
                                        <Rectangle Width="3" Height="12" Fill="{Binding SignalBrush}" Margin="1,0,0,0" VerticalAlignment="Bottom" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Border HorizontalAlignment="Right" Margin="0,0,0,8"
                                    CornerRadius="10" Padding="10,3"
                                    Background="#22FFFFFF">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10" Fill="{Binding StatusBrush}"
                                             VerticalAlignment="Center" Margin="0,0,7,0" />
                                    <TextBlock Text="{Binding StatusText}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{Binding StatusBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <ui:Button Appearance="Primary" Icon="{ui:SymbolIcon Play24}" Content="Iniciar"
                                           Command="{Binding StartCommand}" Margin="0,0,8,0" />
                                <ui:Button Icon="{ui:SymbolIcon Stop24}" Content="Detener"
                                           Command="{Binding StopCommand}" Margin="0,0,8,0" />
                                <ui:Button Icon="{ui:SymbolIcon ArrowClockwise24}" Content="Reiniciar"
                                           Command="{Binding RestartCommand}" Margin="0,0,8,0" />
                                <ui:Button Icon="{ui:SymbolIcon Settings24}" Content="Configurar"
                                           Command="{Binding DataContext.ConfigureServerCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                           ToolTip="Editar server.properties de forma visual" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Aviso: encendido pero sin túnel de Playit -->
                        <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10,0,0" Padding="10,6"
                                CornerRadius="6" Background="#33E05561" BorderBrush="#E05561" BorderThickness="1"
                                Visibility="{Binding ShowTunnelWarning, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Warning24" Foreground="#FF8A8A" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Foreground="#FFC9C9" TextWrapping="Wrap" VerticalAlignment="Center"
                                           Text="El servidor está encendido en tu PC, pero el túnel de Playit está apagado: los jugadores no pueden entrar desde Internet. Activa Playit (botón &quot;Servicio&quot;)." />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Tarjetas de estado -->
                    <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
                        <Border Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="CPU" Style="{StaticResource StatLabel}" />
                                <TextBlock Text="{Binding CpuText}" Style="{StaticResource StatValue}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="RAM" Style="{StaticResource StatLabel}" />
                                <TextBlock Text="{Binding RamText}" Style="{StaticResource StatValue}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="Tiempo activo" Style="{StaticResource StatLabel}" />
                                <TextBlock Text="{Binding UptimeText}" Style="{StaticResource StatValue}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="Puerto" Style="{StaticResource StatLabel}" />
                                <TextBlock Text="{Binding PortText}" Style="{StaticResource StatValue}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Playit.gg -->
                    <Border Grid.Row="2" Style="{StaticResource StatCard}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Playit.gg" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding PlayitStatusText}" FontSize="12" Opacity="0.7" />
                            </StackPanel>
                            <ui:TextBox Grid.Column="1" Margin="16,0"
                                        Text="{Binding TunnelAddress, UpdateSourceTrigger=LostFocus}"
                                        PlaceholderText="Se detecta sola, o pega aquí la dirección del túnel..."
                                        VerticalAlignment="Center" />
                            <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Copy24}" Content="Copiar"
                                       Command="{Binding CopyTunnelAddressCommand}" Margin="0,0,8,0" />
                            <ui:Button Grid.Column="3" Icon="{ui:SymbolIcon AddCircle24}" Content="Crear túnel"
                                       Command="{Binding DataContext.CreateTunnelForSelectedCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                       Margin="0,0,8,0"
                                       ToolTip="Crear el túnel de Playit para este servidor (por su puerto)" />
                            <ui:Button Grid.Column="4" Icon="{ui:SymbolIcon Open24}" Content="Web"
                                       Command="{Binding OpenPlayitDashboardCommand}" Margin="0,0,8,0"
                                       ToolTip="Abrir el panel de Playit.gg para crear o ver túneles" />
                            <ui:Button Grid.Column="5" Icon="{ui:SymbolIcon Power24}" Content="Servicio"
                                       Command="{Binding TogglePlayitCommand}"
                                       ToolTip="Iniciar/detener el servicio de Playit (puede requerir administrador)" />
                        </Grid>
                    </Border>

                    <!-- Pestañas: Consola / Jugadores -->
                    <TabControl Grid.Row="3" Background="Transparent" BorderThickness="0">
                        <TabItem Header="Consola">
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                    <!-- Consola -->
                    <Border Grid.Row="0" Style="{StaticResource StatCard}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="12,8">
                                <TextBlock Text="Consola" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <ui:Button HorizontalAlignment="Right" Icon="{ui:SymbolIcon Eraser24}"
                                           Content="Limpiar" Command="{Binding ClearConsoleCommand}"
                                           Padding="8,2" />
                            </Grid>
                            <ListBox Grid.Row="1"
                                     x:Name="ConsoleList"
                                     ItemsSource="{Binding ConsoleLines}"
                                     b:AutoScrollBehavior.AutoScroll="True"
                                     FontFamily="Cascadia Mono, Consolas, monospace"
                                     FontSize="12"
                                     Background="#1E1E1E"
                                     BorderThickness="0"
                                     Padding="0,0,0,4"
                                     SelectionMode="Extended"
                                     PreviewKeyDown="ConsoleList_PreviewKeyDown"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.ScrollUnit="Pixel">
                                <ListBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Copiar selección" Click="ConsoleCopy_Click" />
                                        <MenuItem Header="Copiar todo" Click="ConsoleCopyAll_Click" />
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="2,0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="MinHeight" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                                   Foreground="#DDDDDD" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- Caja de comandos -->
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0"
                                    Text="{Binding CommandText, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Escribe un comando (p.ej. say hola, op Alex, stop) y pulsa Enter..."
                                    Margin="0,0,8,0">
                            <ui:TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SendCommandCommand}" />
                            </ui:TextBox.InputBindings>
                        </ui:TextBox>

                        <!-- Ayuda de comandos -->
                        <ToggleButton Grid.Column="1" x:Name="CommandHelpToggle" Margin="0,0,8,0"
                                      IsChecked="{Binding IsCommandHelpOpen, Mode=TwoWay}"
                                      ToolTip="Ver comandos disponibles y qué hacen"
                                      Background="Transparent" BorderThickness="1" Padding="10,0"
                                      BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="QuestionCircle24" Margin="0,0,6,0" />
                                <TextBlock Text="Comandos" VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>

                        <Popup PlacementTarget="{Binding ElementName=CommandHelpToggle}" Placement="Top"
                               IsOpen="{Binding IsCommandHelpOpen, Mode=TwoWay}"
                               StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade"
                               HorizontalOffset="0" VerticalOffset="-6">
                            <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1"
                                    CornerRadius="8" Width="460" MaxHeight="380" Padding="6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Margin="8,6,8,8" Opacity="0.8" TextWrapping="Wrap"
                                               Text="Haz clic en un comando para ponerlo en la caja y completar los datos. Estos comandos solo funcionan con el servidor encendido." />
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding CommandHelp}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button HorizontalContentAlignment="Stretch" Margin="2"
                                                            Background="Transparent" BorderThickness="0" Padding="8,6"
                                                            Command="{Binding DataContext.UseCommandCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                                       FontFamily="Cascadia Mono, Consolas, monospace" />
                                                            <TextBlock Text="{Binding Description}" FontSize="12"
                                                                       Opacity="0.7" TextWrapping="Wrap" Margin="0,2,0,0" />
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Popup>

                        <ui:Button Grid.Column="2" Appearance="Primary" Icon="{ui:SymbolIcon Send24}"
                                   Content="Enviar" Command="{Binding SendCommandCommand}" />
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Jugadores">
                            <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Gestión de jugadores" FontWeight="SemiBold" FontSize="15"
                                                   VerticalAlignment="Center" />
                                        <ui:Button HorizontalAlignment="Right" Icon="{ui:SymbolIcon ArrowClockwise24}"
                                                   Content="Actualizar" Padding="8,2"
                                                   Command="{Binding RefreshPlayersCommand}" />
                                    </Grid>

                                    <!-- Conectados -->
                                    <Border Style="{StaticResource StatCard}" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding ConnectedPlayers.Count, StringFormat=Conectados ahora ({0})}" />
                                            <TextBlock Style="{StaticResource StatLabel}"
                                                       Text="Acciones disponibles con el servidor encendido." />
                                            <ItemsControl ItemsSource="{Binding ConnectedPlayers}" Margin="0,6,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center" />
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                <ui:Button Content="OP" Padding="8,2" Margin="0,0,6,0"
                                                                           Command="{Binding DataContext.OpPlayerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                           CommandParameter="{Binding}" />
                                                                <ui:Button Content="Expulsar" Padding="8,2" Margin="0,0,6,0"
                                                                           Command="{Binding DataContext.KickPlayerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                           CommandParameter="{Binding}" />
                                                                <ui:Button Content="Banear" Appearance="Danger" Padding="8,2"
                                                                           Command="{Binding DataContext.BanPlayerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                           CommandParameter="{Binding}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <!-- Operadores -->
                                    <Border Style="{StaticResource StatCard}" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding OpPlayers.Count, StringFormat=Operadores ({0})}" />
                                            <ItemsControl ItemsSource="{Binding OpPlayers}" Margin="0,6,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center" />
                                                            <ui:Button Grid.Column="1" Content="Quitar OP" Padding="8,2"
                                                                       Command="{Binding DataContext.DeopPlayerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                       CommandParameter="{Binding}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <!-- Lista blanca -->
                                    <Border Style="{StaticResource StatCard}" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding WhitelistPlayers.Count, StringFormat=Lista blanca ({0})}" />
                                            <TextBlock Style="{StaticResource StatLabel}"
                                                       Text="Solo estos jugadores pueden entrar (si la lista blanca está activada en Configurar)." />
                                            <Grid Margin="0,8,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ui:TextBox Grid.Column="0" Margin="0,0,8,0"
                                                            Text="{Binding NewWhitelistName, UpdateSourceTrigger=PropertyChanged}"
                                                            PlaceholderText="Nombre del jugador (p. ej. Steve)">
                                                    <ui:TextBox.InputBindings>
                                                        <KeyBinding Key="Return" Command="{Binding AddToWhitelistCommand}" />
                                                    </ui:TextBox.InputBindings>
                                                </ui:TextBox>
                                                <ui:Button Grid.Column="1" Appearance="Primary" Icon="{ui:SymbolIcon PersonAdd24}"
                                                           Content="Añadir" Command="{Binding AddToWhitelistCommand}" />
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding WhitelistPlayers}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center" />
                                                            <ui:Button Grid.Column="1" Content="Quitar" Padding="8,2"
                                                                       Command="{Binding DataContext.RemoveFromWhitelistCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                       CommandParameter="{Binding}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <!-- Baneados -->
                                    <Border Style="{StaticResource StatCard}" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding BannedPlayers.Count, StringFormat=Baneados ({0})}" />
                                            <ItemsControl ItemsSource="{Binding BannedPlayers}" Margin="0,6,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,3">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center" />
                                                            <ui:Button Grid.Column="1" Content="Desbanear" Padding="8,2"
                                                                       Command="{Binding DataContext.PardonPlayerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                       CommandParameter="{Binding}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <!-- Conocidos -->
                                    <Border Style="{StaticResource StatCard}" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding KnownPlayers.Count, StringFormat=Han entrado alguna vez ({0})}" />
                                            <ItemsControl ItemsSource="{Binding KnownPlayers}" Margin="0,6,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" Margin="0,3" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
